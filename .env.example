# Copy this file to .env and fill in your Alpaca paper trading credentials.
# Never commit .env to version control.

# Alpaca API credentials — get these from https://app.alpaca.markets/paper-trading
APCA_API_KEY_ID=your_paper_api_key_here
APCA_API_SECRET_KEY=your_paper_secret_key_here

# Paper trading endpoint (leave as-is for paper; swap to https://api.alpaca.markets for live)
APCA_BASE_URL=https://paper-api.alpaca.markets

# Discord webhook for trade notifications (optional — leave blank to disable)
DISCORD_WEBHOOK_URL=
